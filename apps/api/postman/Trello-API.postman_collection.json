{
  "info": {
    "name": "Trello API (Nest)",
    "description": "Postman Collection v2.1 — import into **HTTPie Desktop** via File → Import (or drag JSON). Set `token` (Clerk JWT) and ids from responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "listId", "value": "" },
    { "key": "cardId", "value": "" },
    { "key": "commentId", "value": "" },
    { "key": "checklistId", "value": "" },
    { "key": "checkItemId", "value": "" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET users/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "DELETE users/me",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "GET workspaces",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/workspaces"
          }
        },
        {
          "name": "GET workspace by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "POST workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My workspace\",\n  \"description\": null\n}"
            },
            "url": "{{baseUrl}}/workspaces"
          }
        },
        {
          "name": "PATCH workspace",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed workspace\"\n}"
            },
            "url": "{{baseUrl}}/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "DELETE workspace",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/workspaces/{{workspaceId}}"
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "GET boards",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/boards"
          }
        },
        {
          "name": "GET board by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/boards/{{boardId}}"
          }
        },
        {
          "name": "POST board",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My board\",\n  \"workspaceId\": \"{{workspaceId}}\"\n}"
            },
            "url": "{{baseUrl}}/boards"
          }
        },
        {
          "name": "PATCH board",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated board\",\n  \"background\": \"#1e293b\",\n  \"closed\": false\n}"
            },
            "url": "{{baseUrl}}/boards/{{boardId}}"
          }
        },
        {
          "name": "DELETE board",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}"
          }
        }
      ]
    },
    {
      "name": "Lists",
      "item": [
        {
          "name": "GET lists by board",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}/lists"
          }
        },
        {
          "name": "POST list",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"To Do\"\n}" },
            "url": "{{baseUrl}}/boards/{{boardId}}/lists"
          }
        },
        {
          "name": "GET list by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/lists/{{listId}}"
          }
        },
        {
          "name": "PATCH list",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"In Progress\",\n  \"closed\": false\n}"
            },
            "url": "{{baseUrl}}/lists/{{listId}}"
          }
        },
        {
          "name": "DELETE list",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/lists/{{listId}}"
          }
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "GET cards by list",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/lists/{{listId}}/cards"
          }
        },
        {
          "name": "POST card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New card\",\n  \"description\": \"Optional\"\n}"
            },
            "url": "{{baseUrl}}/lists/{{listId}}/cards"
          }
        },
        {
          "name": "GET card by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}"
          }
        },
        {
          "name": "PATCH card (move list)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed\",\n  \"listId\": \"{{listId}}\",\n  \"pos\": 1000\n}"
            },
            "url": "{{baseUrl}}/cards/{{cardId}}"
          }
        },
        {
          "name": "DELETE card",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "GET comments by card",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}/comments"
          }
        },
        {
          "name": "POST comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello from HTTPie\"\n}"
            },
            "url": "{{baseUrl}}/cards/{{cardId}}/comments"
          }
        },
        {
          "name": "GET comment by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/comments/{{commentId}}"
          }
        },
        {
          "name": "PATCH comment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Edited comment\"\n}"
            },
            "url": "{{baseUrl}}/comments/{{commentId}}"
          }
        },
        {
          "name": "DELETE comment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/comments/{{commentId}}"
          }
        }
      ]
    },
    {
      "name": "Checklists",
      "item": [
        {
          "name": "GET checklists by card",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}/checklists"
          }
        },
        {
          "name": "POST checklist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Checklist\"\n}" },
            "url": "{{baseUrl}}/cards/{{cardId}}/checklists"
          }
        },
        {
          "name": "GET checklist by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/checklists/{{checklistId}}"
          }
        },
        {
          "name": "PATCH checklist",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed checklist\"\n}"
            },
            "url": "{{baseUrl}}/checklists/{{checklistId}}"
          }
        },
        {
          "name": "DELETE checklist",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/checklists/{{checklistId}}"
          }
        },
        {
          "name": "GET checklist items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/checklists/{{checklistId}}/items"
          }
        },
        {
          "name": "POST checklist item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Item 1\",\n  \"completed\": false\n}"
            },
            "url": "{{baseUrl}}/checklists/{{checklistId}}/items"
          }
        },
        {
          "name": "GET checklist item by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/checklist-items/{{checkItemId}}"
          }
        },
        {
          "name": "PATCH checklist item",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Done item\",\n  \"completed\": true\n}"
            },
            "url": "{{baseUrl}}/checklist-items/{{checkItemId}}"
          }
        },
        {
          "name": "DELETE checklist item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/checklist-items/{{checkItemId}}"
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "POST webhooks/clerk (signed by Clerk — not Bearer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/webhooks/clerk",
            "description": "Use real Svix/Clerk headers + body from dashboard tests; empty body will fail verification."
          }
        }
      ]
    }
  ]
}
