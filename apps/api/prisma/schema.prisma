// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
  // App-local client so monorepo `prisma generate` in other packages cannot overwrite
  // this schema’s types on the shared `@prisma/client` install.
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql" // Or "mysql" / "sqlite"
}

enum BoardBackgroundBrightness {
  light
  dark
}

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  boards              Board[]
  workspaces          Workspace[]
  comments            Comment[]
  uploadedAttachments Attachment[]
  assignedCards       Card[]          @relation("CardAssignee")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  boards      Board[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model Board {
  id                       String                     @id @default(uuid())
  name                     String
  shortLink                String?                    @unique
  background               String? // Legacy: hex color or image URL
  backgroundImage          String?
  backgroundBrightness     BoardBackgroundBrightness  @default(light)
  backgroundBottomColor    String?
  backgroundTopColor       String?
  backgroundColor          String?
  starred                  Boolean                    @default(false)
  closed                   Boolean                    @default(false)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists       List[]
  cards       Card[]
  labels      Label[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([userId])
}

model List {
  id        String   @id @default(uuid())
  name      String
  pos       Float // Trello's midpoint sorting logic
  closed    Boolean  @default(false)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Card {
  id          String       @id @default(uuid())
  name        String
  description String?      @db.Text
  pos         Float
  closed      Boolean      @default(false)
  dueDate     DateTime?
  /// Optional public slug (unique among cards). Legacy rows may be null; resolvable by `id` in API.
  shortLink   String?      @unique
  /// Solid cover (e.g. hex). Mutually exclusive with `coverImage` when both set; prefer image in API normalization.
  coverColor  String?
  /// Image URL for the card cover. Mutually exclusive with `coverColor` when both set.
  coverImage  String?
  listId      String
  list        List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  boardId     String
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  checklists  Checklist[]
  comments    Comment[]
  labels      Label[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]

  @@index([boardId])
  @@index([listId])
  @@index([assigneeId])
}

/// Board-scoped tags; cards link via implicit many-to-many.
model Label {
  id      String @id @default(uuid())
  name    String
  color   String? // e.g. hex or preset key
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@index([boardId])
}

model Checklist {
  id     String      @id @default(uuid())
  name   String
  pos    Float
  cardId String
  card   Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items  CheckItem[]

  @@index([cardId])
}

model CheckItem {
  id          String    @id @default(uuid())
  name        String
  pos         Float
  completed   Boolean   @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model Comment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cardId])
  @@index([authorId])
}

model Attachment {
  id           String   @id @default(uuid())
  name         String // File name or display name
  url          String // S3 link, Cloudinary URL, or external link
  edgeColor    String? // Trello uses this to theme the card cover
  cardId       String
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([cardId])
  @@index([uploadedById])
}
