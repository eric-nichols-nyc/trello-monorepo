// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql" // Or "mysql" / "sqlite"
}

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  boards     Board[]
  workspaces Workspace[]
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  boards      Board[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Board {
  id          String    @id @default(uuid())
  name        String
  background  String? // Store hex color or image URL
  closed      Boolean   @default(false)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  lists       List[]
  cards       Card[] // Redundant but useful for board-wide card queries
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model List {
  id        String   @id @default(uuid())
  name      String
  pos       Float // Trello's midpoint sorting logic
  closed    Boolean  @default(false)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id          String       @id @default(uuid())
  name        String
  description String?      @db.Text
  pos         Float
  closed      Boolean      @default(false)
  dueDate     DateTime?
  listId      String
  list        List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  boardId     String
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  checklists  Checklist[]
  comments    Comment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
}

model Checklist {
  id     String      @id @default(uuid())
  name   String
  pos    Float
  cardId String
  card   Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items  CheckItem[]
}

model CheckItem {
  id          String    @id @default(uuid())
  name        String
  pos         Float
  completed   Boolean   @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Attachment {
  id        String   @id @default(uuid())
  name      String // File name or display name
  url       String // S3 link, Cloudinary URL, or external link
  edgeColor String? // Trello uses this to theme the card cover
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
