# Copy to `.env` and fill in. When you add a variable here, add the same key in
# Vercel → Project → Settings → Environment Variables (and any other hosts).

# Database (Neon / Postgres)
DATABASE_URL=

# Clerk (API + webhooks)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret from Clerk dashboard (svix secret)
CLERK_WEBHOOK_SECRET=
# Optional: comma-separated frontend origins for JWT verification
# CLERK_AUTHORIZED_PARTIES=https://your-app.vercel.app,http://localhost:3000

# Cloudinary — either a single URL:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# or all three:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Local scripts only (not required for the running API) ---
# CLERK_USER_ID=
# CLERK_JWT_TEMPLATE=default
# SEED_CLERK_USER_ID=
# SEED_WORKSPACE_ID=
# SEED_EMAIL=
